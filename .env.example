# ClimatePulse API Keys
# Copy to .env and fill in your keys

# NOAA Climate Data Online — register at https://www.ncei.noaa.gov/cdo-web/token
NOAA_API_TOKEN=

# EIA Open Data — register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# EPA — No API key needed. Using bulk CSV downloads from:
# https://aqs.epa.gov/aqsweb/airdata/download_files.html

# GCP Project (for Cloud Run dashboard deployment)
GCP_PROJECT_ID=
GCP_REGION=us-central1
